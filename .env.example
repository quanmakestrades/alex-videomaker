# videomaker environment variables.
# Copy this to ~/.videomaker/.env and fill in what you actually use.
# The `videomaker auth setup` command will do this interactively.
#
# Only set keys for providers you've configured. Others can be left blank.
# File should be chmod 600.

# --- LLM ---
ANTHROPIC_API_KEY=""        # claude — https://console.anthropic.com/settings/keys
ANTHROPIC_MODEL="claude-sonnet-4-6"   # optional override
GEMINI_API_KEY=""           # gemini LLM + TTS + image — https://aistudio.google.com/app/apikey
OLLAMA_HOST="http://127.0.0.1:11434"  # local ollama, if used
OLLAMA_MODEL="llama3.1:8b"

# --- TTS ---
# Gemini TTS reuses GEMINI_API_KEY above. No extra key needed.
GEMINI_TTS_MODEL="gemini-2.5-flash-preview-tts"
GEMINI_TTS_VOICE="Kore"

AI33PRO_API_KEY=""          # https://ai33.pro/app/api-document (requires premium)
AI33PRO_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
AI33PRO_MODEL_ID="eleven_multilingual_v2"

ELEVENLABS_API_KEY=""       # https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

OPENAI_API_KEY=""           # TTS + DALL-E — https://platform.openai.com/api-keys
OPENAI_TTS_VOICE="nova"

XAI_API_KEY=""              # https://console.x.ai
XAI_TTS_VOICE="eve"

# --- Image ---
# Nanobanana reuses GEMINI_API_KEY.
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"   # free tier, ~500/day
# Options: gemini-3.1-flash-image-preview (paid), gemini-3-pro-image-preview (paid, 4K)

OPENAI_IMAGE_MODEL="gpt-image-1"

REPLICATE_API_TOKEN=""      # https://replicate.com/account/api-tokens
REPLICATE_IMAGE_MODEL="black-forest-labs/flux-schnell"

# --- Email handoff ---
# Gmail app password: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""                # defaults to SMTP_USER

# --- Telegram status updates ---
# When passed --telegram-chat-id to `videomaker run`, updates post to that chat.
TELEGRAM_BOT_TOKEN=""       # from @BotFather on Telegram

# --- Skill-wide ---
VIDEOMAKER_ASSISTANT_EMAIL=""   # overrides config.yaml assistant_email
VIDEOMAKER_HOME=""              # defaults to ~/.videomaker
